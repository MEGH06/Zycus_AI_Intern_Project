# ── LLM provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to "groq", "openai", or "local" (deterministic fallback).
LLM_PROVIDER=groq

# Groq (preferred – fast, free-tier available)
GROQ_API_KEY=

# OpenAI (optional alternative)
OPENAI_API_KEY=

# Model name – must match the chosen provider's catalogue.
# Groq examples : llama3-8b-8192  |  mixtral-8x7b-32768  |  llama3-70b-8192
# OpenAI example: gpt-4o-mini
LLM_MODEL=llama3-8b-8192
LLM_TEMPERATURE=0

# ── Data paths ────────────────────────────────────────────────────────────────
DATA_DIR=data
KB_DIR=knowledge-base
